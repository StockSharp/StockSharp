<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="..\..\common_samples_netwindows.props" />
  <PropertyGroup>
    <!-- The optimizer runs many parallel, month-long backtests that allocate heavily; Server GC
         roughly halves the run time versus the default Workstation GC on multi-core machines. -->
    <ServerGarbageCollection>true</ServerGarbageCollection>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="..\01_History\SmaStrategy.cs" Link="SmaStrategy.cs" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Ecng.Compilation.Roslyn" Version="$(EcngVer)" />

    <PackageReference Include="StockSharp.Xaml.Charting" Version="$(StockSharpVer)" />
    <PackageReference Include="StockSharp.Samples.HistoryData" Version="$(StockSharpVer)" />
  </ItemGroup>
</Project>